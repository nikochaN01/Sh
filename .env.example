# ==============================================================================
# SHOPIFY AUTOSHOPIFY - ENVIRONMENT CONFIGURATION
# ==============================================================================
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit .env file to version control!
# ==============================================================================

# ============================================================================
# API CONFIGURATION
# ============================================================================
# Main API key for authentication
API_KEY=your-secure-api-key-here

# API URL for the main application
API_URL=http://localhost:5000

# Captcha Solver API configuration
CAPTCHA_API_URL=http://localhost:5000
CAPTCHA_API_KEY=your-captcha-api-key-here

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
# Enable/disable debug mode (True/False)
DEBUG=False

# Rate limit - requests per minute
RATE_LIMIT=60

# Request timeout in seconds
REQUEST_TIMEOUT=15

# SSL verification (True/False) - Set to False only for development
SSL_VERIFY=True

# ============================================================================
# CAPTCHA SOLVER SETTINGS
# ============================================================================
# Enable/disable automatic captcha solving
USE_CAPTCHA_SOLVER=True

# Captcha solver timeout
CAPTCHA_TIMEOUT=30

# Maximum retry attempts for captcha solving
CAPTCHA_MAX_RETRIES=3

# ============================================================================
# SHOPIFY SETTINGS
# ============================================================================
# Shopify store URL (without https://)
SHOPIFY_STORE_URL=example.myshopify.com

# Checkout data
CHECKOUT_EMAIL=test@example.com
CHECKOUT_FIRST_NAME=John
CHECKOUT_LAST_NAME=Doe
CHECKOUT_ADDRESS=4024 College Point Boulevard
CHECKOUT_CITY=Flushing
CHECKOUT_STATE=NY
CHECKOUT_ZIP=11354

# ============================================================================
# PROXY SETTINGS
# ============================================================================
# Use proxies (True/False)
USE_PROXIES=False

# Proxy URL format: http://ip:port or http://user:pass@ip:port
PROXY_URL=http://proxy-ip:proxy-port

# ============================================================================
# LOGGING SETTINGS
# ============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path
LOG_FILE=logs/app.log

# ============================================================================
# DEPLOYMENT SETTINGS
# ============================================================================
# Port to run the application on
PORT=5000

# Host to bind to
HOST=0.0.0.0

# Number of workers (for production)
WORKERS=4

# ============================================================================
# SECURITY SETTINGS
# ============================================================================
# Secret key for Flask sessions
SECRET_KEY=your-secret-key-change-this

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5000

# Rate limit key (for rate limiting)
RATE_LIMIT_STORAGE=memory

# ==============================================================================
# END OF CONFIGURATION
# ==============================================================================
